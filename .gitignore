# ROS 2 / colcon build artifacts
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/

# Third-party packages imported via `vcs import` (see ros2_ws/team_b.repos)
ros2_ws/src/third_party/

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg-info/
*.egg
.pytest_cache/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*.bak
*~

# OS
.DS_Store
Thumbs.db

# TF tree debug outputs (generated by ros2 run tf2_tools view_frames)
frames_*.gv
frames_*.pdf

# Claude Code AI assistant session memory (local only)
.claude/

# ROS bags
*.bag
*.db3
*.mcap
*.sqlite3

# Generated run outputs: keep README and curated examples only
results/*
!results/README.md
!results/examples/
!results/examples/**

# Experiments — keep folder skeleton, ignore content
experiments/runs/*
!experiments/runs/.gitkeep
experiments/plots/*
!experiments/plots/.gitkeep

# Reports build artifacts
docs/report/*.aux
docs/report/*.log
docs/report/*.out
docs/report/*.toc
docs/report/*.synctex.gz

# uv / local Python environment
.venv/

# Local machine-specific project config
config/local_env.sh
