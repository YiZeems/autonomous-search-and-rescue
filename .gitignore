.vscode/
.idea/

# ROS bags and databases
*.bag
*.db3
*.sqlite3

# Generated run outputs: keep README and curated examples only
results/*
!results/README.md
!results/examples/
!results/examples/**

# uv / local Python environment
.venv/
.pytest_cache/

# Local machine-specific project config
config/local_env.sh
