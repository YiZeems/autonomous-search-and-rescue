<!--
  Search & Rescue mission tree (BehaviorTree.CPP v3, loadable in Groot).

  The BT ORCHESTRATES the mission (assignment: "decision-making with Behavior Trees,
  not FSMs"). A plain Sequence (with memory: it resumes at the RUNNING child and only
  advances on SUCCESS) runs the phases in order:

    1. WaitForMap     -> FAILURE until SLAM publishes /map (sequence retries next tick)
    2. ExplorePhase   -> raises /mission/explore_enable; RUNNING until coverage >= threshold,
                         then clears it (stops the explorer) and returns SUCCESS
    3. InspectPhase   -> raises /mission/inspect_enable (the inspection_node visits the
                         map-derived per-room poses); RUNNING until /mission/inspect_done
    4. VictimsFound    -> SUCCESS once the registered victim count reaches min_count
    5. PublishMissionDone -> latches /mission_done = true

  The robot's actions run in the Python nodes (frontier_explorer_node, inspection_node);
  the BT decides WHEN each phase starts and stops via the /mission/* topics. After the
  Sequence returns SUCCESS the runner idles, keeping /mission_done latched.
-->
<root main_tree_to_execute="Mission">
  <BehaviorTree ID="Mission">
    <Sequence name="search_and_rescue_mission">
      <WaitForMap name="wait_for_slam_map"/>
      <ExplorePhase name="explore_until_coverage" threshold="0.90"/>
      <InspectPhase name="inspect_discovered_rooms"/>
      <VictimsFound name="report_victims" min_count="1"/>
      <PublishMissionDone name="finalize"/>
    </Sequence>
  </BehaviorTree>
</root>
